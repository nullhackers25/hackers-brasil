                </tr>
            </thead>

            <tbody>
                <?php foreach ($usuarios as $linha): ?>
                <tr>
                    <td><?= htmlspecialchars($linha['id']) ?></td>
                    <td><?= htmlspecialchars($linha['nome_completo']) ?></td>
                    <td><?= htmlspecialchars($linha['email']) ?></td>
